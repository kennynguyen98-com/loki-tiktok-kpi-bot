# Copy file này thành .env rồi điền vào
# Không commit file .env lên git

# WordPress (gipfulfillment.com)
# Dung tai khoan rieng cho agent, khong dung tai khoan chinh/admin.
# Uu tien user role Editor hoac role custom chi du quyen tao/sua bai nhap.
# Lấy tại: WP Dashboard → Users → Agent Profile → Application Passwords → Add New
WP_USER=wp-agent-editor
WP_APP_PASS=xxxx xxxx xxxx xxxx xxxx xxxx

# Safety switch
# Mac dinh de trong/0 => chi luu local. Chi set =1 khi ban thuc su muon day bai len WordPress o che do draft.
WP_ALLOW_DRAFTS=0

# AI Writer (chọn 1 trong 2)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Ảnh (tuỳ chọn)
UNSPLASH_ACCESS_KEY=

# Telegram KPI Bot (Loki Tran only)
# Tao bot voi @BotFather de lay token
TELEGRAM_BOT_TOKEN=

# Khung gio nhac KPI moi ngay, dinh dang HH:MM, tach boi dau phay
TG_REMINDER_TIMES=09:00,13:00,20:30

# Khung gio gui report tong quan dau ngay
TG_MORNING_STATUS_HOUR=08
TG_MORNING_STATUS_MINUTE=30

# Google Sheet sync (2 chiều nhẹ: bot -> sheet + snapshot nền tảng)
# Có thể dùng 1 trong 2: GSHEET_URL hoặc GSHEET_ID
GSHEET_URL=
GSHEET_ID=

# File JSON service account của Google (đã share quyền Editor vào sheet)
GSERVICE_ACCOUNT_FILE=

# Tên tab trong sheet
GSHEET_TAB_WEEKLY=Phân tích kênh hàng tuần
GSHEET_TAB_INFO=Thông tin

# Lịch tự động sync sheet lúc 12h
TG_SHEET_SYNC_HOUR=12
TG_SHEET_SYNC_MINUTE=00

# Lịch gửi báo cáo KPI lúc 17h
TG_EVENING_REPORT_HOUR=17
TG_EVENING_REPORT_MINUTE=00

# API key tùy chọn cho YouTube snapshot
YOUTUBE_API_KEY=
